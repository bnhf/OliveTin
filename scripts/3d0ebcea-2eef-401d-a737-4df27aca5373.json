{
"name": "FruitDeepLinks - HBO Max v1.0 (FireTV and AndroidTV)",
    "author": "bnhf",
    "version": "1.0",
    "description": "HBO Max for FruitDeepLinks. Compatible with FireTV and AndroidTV devices.",
    "uuid": "3d0ebcea-2eef-401d-a737-4df27aca5373",
    "global_options": {
        "wait_for_video_playback_detection": false,
        "use_fixed_delay": true,
        "fixed_delay_seconds": 5,
        "wait_after_post_playback_start_commands_seconds": 0
    },
    "pre_tune_commands": [
        "input keyevent KEYCODE_MEDIA_STOP"
    ],
    "tune_commands": [
        "am start -W -a android.intent.action.VIEW -d '||TARGET_URL_OR_IDENTIFIER||' '||TARGET_PACKAGE_NAME||'"
    ],
    "tune_match_text_commands": [
        {
            "match_text": [
                "kids",
                "add profile",
                "watch",
                "live"
            ],
            "commands": [
                "input keyevent KEYCODE_DPAD_CENTER"
            ],
            "start_checking_after_seconds": 5
        }
    ],
    "post_playback_start_commands": [],
    "post_tune_commands": [
        "input keyevent KEYCODE_MEDIA_STOP",
        "input keyevent KEYCODE_MEDIA_PAUSE"
    ],
    "timed_keep_active_commands": []
}